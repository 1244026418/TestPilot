# MySQL is the default database for this project version.
# 1. Create the database manually in Navicat, or run scripts/init_mysql.py after filling these values.
# 2. You can also set TESTPILOT_DATABASE_URL directly if you prefer one full SQLAlchemy URL.
TESTPILOT_DB_DRIVER=mysql
TESTPILOT_MYSQL_HOST=127.0.0.1
TESTPILOT_MYSQL_PORT=3306
TESTPILOT_MYSQL_USER=root
TESTPILOT_MYSQL_PASSWORD=your_mysql_password
TESTPILOT_MYSQL_DATABASE=testpilot
TESTPILOT_DATABASE_URL=

TESTPILOT_SECRET_KEY=change-me-in-real-projects
TESTPILOT_REPORT_DIR=./reports

# Optional. The MVP works without an LLM key by using a rule-based generator.
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
