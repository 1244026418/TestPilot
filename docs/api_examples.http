@baseUrl = http://127.0.0.1:8000/api
@token = replace-with-login-token

### 健康检查
GET {{baseUrl}}/health

### 注册
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "tester",
  "password": "123456"
}

### 登录
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "tester",
  "password": "123456"
}

### 创建项目
POST {{baseUrl}}/projects
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "登录接口测试",
  "description": "覆盖登录接口的正常、异常和边界场景"
}

### GPT / 规则生成测试用例草稿
POST {{baseUrl}}/ai/generate-cases
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "requirement": "用户登录接口，需要校验账号密码、缺少参数和鉴权失败",
  "method": "POST",
  "url": "http://127.0.0.1:8000/demo-target/login",
  "headers": {"Content-Type": "application/json"},
  "body": {"username": "demo", "password": "123456"},
  "expected_status": 200,
  "use_ai": true
}
